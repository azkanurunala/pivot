{
  "expo": {
    "name": "Pivot",
    "slug": "pivot",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080B11",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pivot.game",
      "infoPlist": { "ITSAppUsesNonExemptEncryption": false },
      "entitlements": { "com.apple.developer.game-center": true }
    },
    "android": { "package": "com.pivot.game" },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      ["expo-splash-screen", { "backgroundColor": "#080B11", "resizeMode": "contain" }]
    ],
    "extra": { "eas": { "projectId": "<your-eas-project-id>" } }
  }
}
